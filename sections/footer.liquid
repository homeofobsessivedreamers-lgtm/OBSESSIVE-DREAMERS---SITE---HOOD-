{% comment %}
  Footer Section - Site footer with links and newsletter
{% endcomment %}

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">{{ settings.footer_copyright | split: '©' | first | default: 'HOME OF OBSESSIVE DREAMERS' }}</div>
        <p class="footer-description">
          The premier destination for music, news, fashion, arts, and sports. 
          Where dreams become legacies.
        </p>
      </div>

      <div class="footer-column">
        <h4 class="footer-heading">Explore</h4>
        <ul class="footer-links">
          <li><a href="/collections/all" class="footer-link">Shop All</a></li>
          <li><a href="/blogs/news" class="footer-link">News</a></li>
          <li><a href="/pages/music" class="footer-link">Music</a></li>
          <li><a href="/pages/fashion" class="footer-link">Fashion</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-heading">Company</h4>
        <ul class="footer-links">
          <li><a href="/pages/about" class="footer-link">About Us</a></li>
          <li><a href="/pages/contact" class="footer-link">Contact</a></li>
          <li><a href="/pages/careers" class="footer-link">Careers</a></li>
          <li><a href="/pages/press" class="footer-link">Press</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-heading">Support</h4>
        <ul class="footer-links">
          <li><a href="/pages/faq" class="footer-link">FAQ</a></li>
          <li><a href="/pages/shipping" class="footer-link">Shipping</a></li>
          <li><a href="/pages/returns" class="footer-link">Returns</a></li>
          <li><a href="/pages/privacy" class="footer-link">Privacy Policy</a></li>
        </ul>
      </div>
    </div>

    <div class="newsletter-section">
      <h3 class="newsletter-title">{{ section.settings.newsletter_title | default: settings.footer_newsletter_title }}</h3>
      <p class="newsletter-text">{{ section.settings.newsletter_text | default: settings.footer_newsletter_text }}</p>
      <form class="newsletter-form" action="/contact#newsletter" method="post">
        <input type="email" 
               name="email" 
               class="newsletter-input" 
               placeholder="Enter your email"
               required>
        <button type="submit" class="btn btn-primary">Subscribe</button>
        <input type="hidden" name="form_type" value="newsletter">
      </form>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">{{ section.settings.copyright_text | default: settings.footer_copyright }}</p>
      
      <div class="footer-social">
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" class="social-link" target="_blank" rel="noopener" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="social-link" target="_blank" rel="noopener" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Join the Movement"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Subscribe for exclusive updates and early access to new releases."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© 2024 Home of Obsessive Dreamers. All rights reserved."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
