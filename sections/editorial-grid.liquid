{% comment %}
  Editorial Grid Section - Editorial style content grid
{% endcomment %}

<section class="section" style="background-color: var(--color-primary);">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="section-divider"></div>
    </div>

    <div class="editorial-grid">
      {%- for i in (1..3) -%}
        {%- assign article = 'article_' | append: i -%}
        {%- assign image_key = 'image_' | append: i -%}
        {%- assign title_key = 'title_' | append: i -%}
        {%- assign category_key = 'category_' | append: i -%}
        {%- assign link_key = 'link_' | append: i -%}

        <a href="{{ section.settings[link_key] | default: '#' }}" 
           class="editorial-card {% if i == 1 %}editorial-card-large{% else %}editorial-card-medium{% endif %}">
          <div class="editorial-card-image">
            {%- if section.settings[image_key] != blank -%}
              {{ section.settings[image_key] | image_url: width: 800 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div style="background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%); width: 100%; height: 100%;"></div>
            {%- endif -%}
          </div>
          <div class="editorial-card-overlay"></div>
          <div class="editorial-card-content">
            {%- if section.settings[category_key] != blank -%}
              <span class="editorial-card-category">{{ section.settings[category_key] }}</span>
            {%- endif -%}
            <h3 class="editorial-card-title">
              {{ section.settings[title_key] | default: 'Featured Content ' | append: i }}
            </h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Latest Stories"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Stay updated with the latest news and trends"
    },
    {
      "type": "header",
      "content": "Card 1 (Large)"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "category_1",
      "label": "Category",
      "default": "MUSIC"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title",
      "default": "The Future of Hip-Hop: Emerging Artists to Watch"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "category_2",
      "label": "Category",
      "default": "FASHION"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title",
      "default": "Streetwear Trends Taking Over 2024"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "category_3",
      "label": "Category",
      "default": "SPORTS"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Title",
      "default": "Breaking Records: Championship Recap"
    },
    {
      "type": "url",
      "id": "link_3",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Editorial Grid"
    }
  ]
}
{% endschema %}
