{% comment %}
  Cart Template - Shopping cart
{% endcomment %}

<div class="cart-template">
  <div class="container">
    <h1 class="cart-title">Shopping Cart</h1>

    {%- if cart.items.size > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" class="cart-form">
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item">
              <div class="cart-item-image">
                {%- if item.image != blank -%}
                  {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  <div style="background: #2a2a2a; width: 100%; height: 100%;"></div>
                {%- endif -%}
              </div>

              <div class="cart-item-info">
                <div class="cart-item-vendor">{{ item.product.vendor }}</div>
                <a href="{{ item.url }}" class="cart-item-title">{{ item.title }}</a>
                
                {%- if item.variant_title != 'Default Title' -%}
                  <div class="cart-item-variant">{{ item.variant_title }}</div>
                {%- endif -%}

                <div class="cart-item-quantity">
                  <input type="number" 
                         name="updates[]" 
                         value="{{ item.quantity }}" 
                         min="1" 
                         class="quantity-input"
                         data-id="{{ item.key }}">
                </div>

                <button type="button" class="cart-item-remove" data-id="{{ item.key }}">
                  Remove
                </button>
              </div>

              <div class="cart-item-price">
                {{ item.line_price | money }}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-summary">
          <h2 class="cart-summary-title">Order Summary</h2>

          <div class="cart-summary-row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="cart-summary-row">
            <span>Shipping</span>
            <span>Calculated at checkout</span>
          </div>

          <div class="cart-summary-row total">
            <span>Total</span>
            <span class="price">{{ cart.total_price | money }}</span>
          </div>

          <button type="submit" name="checkout" class="btn btn-primary cart-checkout-btn">
            Checkout
          </button>

          <div class="cart-note">
            <label for="cart-note" class="cart-note-label">Special instructions</label>
            <textarea name="note" id="cart-note" placeholder="Add a note to your order">{{ cart.note }}</textarea>
          </div>

          {%- if additional_checkout_buttons -%}
            <div class="cart-additional-buttons" style="margin-top: 1rem;">
              {{ additional_checkout_buttons }}
            </div>
          {%- endif -%}
        </div>
      </form>
    {%- else -%}
      <div class="cart-empty">
        <p class="cart-empty-text">Your cart is empty</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">
          Continue Shopping
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  document.querySelectorAll('.cart-item-remove').forEach(function(button) {
    button.addEventListener('click', function() {
      const key = this.dataset.id;
      
      fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: key,
          quantity: 0
        })
      })
      .then(function(response) {
        return response.json();
      })
      .then(function() {
        window.location.reload();
      });
    });
  });
</script>
