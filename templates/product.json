{% comment %}
  Product Template - Single product page
{% endcomment %}

<div class="product-template">
  <div class="container">
    <div class="product-main">
      <div class="product-gallery">
        <div class="product-gallery-main">
          {%- if product.featured_media != blank -%}
            {{ product.featured_media | image_url: width: 1200 | image_tag: 
              class: 'gallery-main-image',
              alt: product.title
            }}
          {%- else -%}
            <div style="background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%); width: 100%; height: 100%;"></div>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-gallery-thumbs">
            {%- for media in product.media -%}
              <div class="product-gallery-thumb {% if forloop.first %}active{% endif %}" 
                   data-src="{{ media | image_url: width: 1200 }}">
                {{ media | image_url: width: 200 | image_tag: loading: 'lazy' }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="product-info">
        {%- if product.vendor != blank -%}
          <div class="product-vendor">{{ product.vendor }}</div>
        {%- endif -%}

        <h1 class="product-title">{{ product.title }}</h1>

        <div class="product-price">
          {%- if product.compare_at_price > product.price -%}
            <span class="compare-at">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          {{ product.price | money }}
          
          {%- if product.available == false -%}
            <span style="color: var(--color-error); margin-left: 1rem;">Sold Out</span>
          {%- endif -%}
        </div>

        <div class="product-description">
          {{ product.description }}
        </div>

        {%- form 'product', product, class: 'product-form', id: 'product-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {%- if product.variants.size > 1 -%}
            {%- for option in product.options_with_values -%}
              <div class="product-variant-options">
                <span class="product-variant-label">{{ option.name }}</span>
                <div class="product-variant-buttons">
                  {%- for value in option.values -%}
                    <button type="button" 
                            class="product-variant-btn {% if option.selected_value == value %}active{% endif %}"
                            data-option-name="{{ option.name }}"
                            data-option-value="{{ value }}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
                <input type="hidden" name="options[{{ option.name }}]" value="{{ option.selected_value }}">
              </div>
            {%- endfor -%}
          {%- endif -%}

          <div class="product-quantity">
            <span class="product-variant-label">Quantity</span>
            <div class="quantity-selector">
              <button type="button" class="quantity-minus">-</button>
              <input type="number" name="quantity" value="1" min="1" class="quantity-input">
              <button type="button" class="quantity-plus">+</button>
            </div>
          </div>

          <button type="submit" 
                  name="add" 
                  class="btn btn-primary product-add-btn"
                  {% if product.available == false %}disabled{% endif %}>
            {%- if product.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- endform -%}

        <div class="product-meta">
          <div class="product-meta-item">
            <span class="product-meta-label">SKU:</span>
            <span>{{ product.selected_or_first_available_variant.sku | default: 'N/A' }}</span>
          </div>
          <div class="product-meta-item">
            <span class="product-meta-label">Category:</span>
            <span>{{ product.collections.first.title | default: 'Uncategorized' }}</span>
          </div>
          {%- if product.tags.size > 0 -%}
            <div class="product-meta-item">
              <span class="product-meta-label">Tags:</span>
              <span>{{ product.tags | join: ', ' }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>
